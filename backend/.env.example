# Use este arquivo apenas quando rodar o backend fora do Docker.

NODE_ENV=development
HOST=0.0.0.0
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=estoque_erp_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estoque_erp_dev?schema=public

PRISMA_BOOTSTRAP_MODE=migrate

JWT_SECRET=change_me
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_EMAIL=admin@estoque.local
DEFAULT_ADMIN_PASSWORD=admin123
DEV_ADMIN_NAME=Admin de Teste
DEV_ADMIN_EMAIL=admin@estoque.local
DEV_ADMIN_PASSWORD=admin123
DEFAULT_COMPANY_NAME=Empresa Dev
DEFAULT_BASE_NAME=Base Principal
DEFAULT_TIMEZONE=America/Sao_Paulo

APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RECOVERY_DEBUG=true

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
