# Preset de desenvolvimento. Mantido em sincronia com o .env.example.

NODE_ENV=development
HOST=0.0.0.0
PORT=3000

DB_HOST=postgres
DB_PORT=5432
DB_NAME=estoque_erp_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/estoque_erp_dev?schema=public

POSTGRES_DB=estoque_erp_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

PRISMA_BOOTSTRAP_MODE=migrate

JWT_SECRET=change_me
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_EMAIL=admin@estoque.local
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_COMPANY_NAME=Empresa Dev
DEFAULT_BASE_NAME=Base Principal
DEFAULT_TIMEZONE=America/Sao_Paulo

APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RECOVERY_DEBUG=true

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

VITE_API_URL=
VITE_BACKEND_TARGET=http://backend:3000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1
