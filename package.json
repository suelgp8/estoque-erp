{
  "name": "estoque-erp",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:logs": "docker compose logs -f postgres",
    "migrate": "npm run prisma:migrate:deploy --workspace backend",
    "dev:user": "npm run dev:user --workspace backend",
    "dev:setup": "npm run db:up && npm run migrate && npm run dev:user",
    "dev": "npm run dev:setup && concurrently -n backend,frontend -c green,cyan \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "start:frontend": "npm run start --workspace frontend",
    "repo:commit": "powershell -ExecutionPolicy Bypass -File .\\scripts\\git-commit.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1"
  }
}
